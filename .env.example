# =========================================
# BotPanel — Fichier de configuration
# Copier en .env et remplir toutes les valeurs
# =========================================

# --- Discord ---
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=000000000000000000
# ID du channel par defaut pour les notifications (si aucun channel n'est specifie)
DISCORD_DEFAULT_CHANNEL_ID=000000000000000000
# Channel dedie aux messages de monitoring (temperature, conso, etc.)
DISCORD_MONITORING_CHANNEL_ID=000000000000000000

# --- Home Assistant ---
HA_BASE_URL=http://192.168.0.11:8123
HA_TOKEN=your_long_lived_access_token_here

# --- API / Site web ---
API_HOST=0.0.0.0
API_PORT=8080
SITE_BASE_URL=https://botpanel.super-nono.cc

# --- Stockage ---
DATABASE_PATH=./data/botpanel.db

# --- Logs ---
LOG_LEVEL=INFO
